# ====================================================
# QCall — Конфигурация для веб-приложения и GitHub Actions
# ====================================================

# -------------------- Аутентификация --------------------
# Секретный ключ для подписи JWT-токенов (сгенерируйте случайную строку)
SECRET_KEY="your-super-secret-key-change-me"

# -------------------- Yandex Object Storage (S3) --------------------
# Эндпоинт для доступа к S3-совместимому хранилищу Yandex Cloud
AWS_ENDPOINT_URL="https://storage.yandexcloud.net"

# Идентификатор и секретный ключ сервисного аккаунта (получить в Yandex Cloud)
AWS_ACCESS_KEY_ID="ваш_статический_ключ_id"
AWS_SECRET_ACCESS_KEY="ваш_статический_ключ_secret"

# Названия бакетов (должны совпадать с именами, созданными в Yandex Cloud)
RAW_BUCKET="raw-recordings"          # для исходных аудиозаписей
REPORTS_BUCKET="analysis-reports"    # для итоговых JSON-отчётов
TRANSCRIPTS_BUCKET="transcripts"     # для JSON-транскриптов

# -------------------- Yandex SpeechKit --------------------
# API-ключ для доступа к SpeechKit (создан в сервисном аккаунте)
SPEECHKIT_API_KEY="ваш_api_ключ"

# ID каталога в Yandex Cloud, где активирован SpeechKit
SPEECHKIT_FOLDER_ID="ваш_folder_id"

# -------------------- GigaChat --------------------
# Авторизационные данные для GigaChat (выдаются в личном кабинете Сбера)
# Обычно это длинная строка вида "ZGFk...==" (Base64)
GIGACHAT_CREDENTIALS="ваши_credentials"

# -------------------- Telegram --------------------
# Токен бота, полученный от @BotFather
TELEGRAM_BOT_TOKEN="ваш_токен_бота"

# ID чата или пользователя, куда отправлять уведомления (для групп — отрицательное число)
TELEGRAM_CHAT_ID="ваш_chat_id"

# -------------------- GitHub Actions --------------------
# Репозиторий в формате "владелец/название-репозитория"
GITHUB_REPO="ваш_username/название_репозитория"

# Персональный токен GitHub (classic) с правами actions:write
GITHUB_TOKEN="github_personal_access_token"